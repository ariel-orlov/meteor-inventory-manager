{
  "schemaVersion": 1,
  "id": "inventory-manager",
  "version": "${version}",
  "name": "Inventory Manager",
  "description": "Smart inventory automation for Meteor Client — auto-sort, PvP loadout, quick deposit, auto-trash, and more.",
  "authors": [
    "ariel-orlov"
  ],
  "contact": {
    "homepage": "https://github.com/ariel-orlov/meteor-inventory-manager",
    "sources": "https://github.com/ariel-orlov/meteor-inventory-manager"
  },
  "icon": "assets/template/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.example.addon.InventoryManagerAddon"
    ]
  },
  "mixins": [
    "inventory-manager.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "80,180,255",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
